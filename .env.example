# Copia este archivo a .env.local y completá los valores.
# Las mismas 5 variables hay que cargarlas en Vercel:
#   Project Settings → Environment Variables (para todos los entornos).
#
# Todas son server-side (sin prefijo NEXT_PUBLIC_): nunca llegan al browser.

# ---- Cloudinary (imágenes de los cuadros) ----
# Dashboard de Cloudinary → Settings → API keys.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Supabase (descripciones de cuadros + usuarios) ----
# Project Settings → Data API → Project URL, y Settings → API Keys (service_role).
# IMPORTANTE: usá la "service_role" key (bypassa RLS). Es secreta de servidor.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Seed opcional del admin (por defecto admin / admin123) ----
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin123
